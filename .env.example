# Smart Clean — production secrets (NEVER commit this file)
# Copy from .env.example and fill in real values.

# --- PostgreSQL ---
POSTGRES_DB=smartclean
POSTGRES_USER=smartclean
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# --- Database (API + bots) ---
# docker-compose.yml sets ConnectionStrings__DefaultConnection automatically.
Database__Provider=PostgreSQL

# --- Public site ---
SITE_URL=https://smartclean.com.ua
Frontend__AllowedOrigins__0=https://smartclean.com.ua
Frontend__AllowedOrigins__1=https://www.smartclean.com.ua

# --- ASP.NET ---
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
DOTNET_ENVIRONMENT=Production

# --- Monobank ---
Monobank__Token=
Monobank__RedirectUrl=https://smartclean.com.ua/profile/orders?paid=1
Monobank__WebhookUrl=

# --- First admin (only created when no admin exists) ---
AdminSeed__Email=admin@smartclean.com.ua
AdminSeed__Password=change-me-strong-admin-password
AdminSeed__Name=Адмін
AdminSeed__Phone=+380000000000

# --- Telegram bots ---
TelegramBot__BotToken=
SupportTelegramBot__BotToken=
HiringTelegramBot__BotToken=
HiringTelegramBot__NotifyChatIds=

# --- Frontend build (used by docker compose build args) ---
VITE_SITE_URL=https://smartclean.com.ua
