# Локальний Docker — скопіюй у .env:
#   copy .env.local.example .env   (Windows)
#   cp .env.local.example .env     (Linux/macOS)

# --- PostgreSQL ---
POSTGRES_DB=smartclean
POSTGRES_USER=smartclean
POSTGRES_PASSWORD=local-dev-postgres-password

# --- Database ---
Database__Provider=PostgreSQL

# --- Локальний сайт (nginx на порту 8080) ---
SITE_URL=http://localhost:8080
VITE_SITE_URL=http://localhost:8080
Frontend__AllowedOrigins__0=http://localhost:8080
Frontend__AllowedOrigins__1=http://127.0.0.1:8080

# --- ASP.NET ---
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
DOTNET_ENVIRONMENT=Production

# --- Monobank (порожньо = без оплати карткою локально) ---
Monobank__Token=
Monobank__RedirectUrl=http://localhost:8080/profile/orders?paid=1
Monobank__WebhookUrl=

# --- Перший адмін (створюється один раз) ---
AdminSeed__Email=admin@smartclean.com.ua
AdminSeed__Password=LocalAdmin123!
AdminSeed__Name=Адмін
AdminSeed__Phone=+380000000000

# --- Telegram (порожньо = боти стартують, але polling вимкнений) ---
TelegramBot__BotToken=
SupportTelegramBot__BotToken=
HiringTelegramBot__BotToken=
HiringTelegramBot__NotifyChatIds=
